# =============================================================================
# Endee — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# C++ build artefacts (Endee C++ engine)
# ---------------------------------------------------------------------------
build/
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
Makefile
*.o
*.a
*.so
*.dylib
ndd
ndd-avx2
ndd-avx512
ndd-neon
ndd-neon-darwin
ndd-sve2

# ---------------------------------------------------------------------------
# Endee runtime data (server storage)
# ---------------------------------------------------------------------------
endee-data/
data/*.binary
data/*.mdbx

# ---------------------------------------------------------------------------
# Python (AI Complaint Assistant backend)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
venv/
.venv/
env/

# HuggingFace model cache (large, auto-downloaded)
.cache/

# Endee Python DB file — auto-created by seed script
data/complaints.jsonl

# ---------------------------------------------------------------------------
# Node / Frontend (AI Complaint Assistant frontend)
# ---------------------------------------------------------------------------
node_modules/
frontend/dist/
frontend/.env.local

# ---------------------------------------------------------------------------
# IDE / Editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
*.swp
*.swo
Thumbs.db

# ---------------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------------
*.log
endee.log

# ---------------------------------------------------------------------------
# Environment secrets
# ---------------------------------------------------------------------------
backend/.env.local
*.secret
